PORT=3000
STRAVA_VERIFY_TOKEN=jouw_zelfbedachte_token_hier
CLIENT_ID=jouw_strava_client_id
CLIENT_SECRET=jouw_strava_secret
VERIFY_TOKEN=jouw_zelfbedachte_token

# Apple Push Notification Service (APNs) configuratie
# Haal deze gegevens uit je Apple Developer account -> "Certificates, Identifiers & Profiles" -> "Keys".
# Let op: Laat deze leeg als je wilt ontwikkelen in "Mock Mode" (bijv. tijdens het testen in de iOS Simulator zonder betaald Apple Developer Account). De backend simuleert dan het versturen van notificaties door ze in de console te printen.
APN_KEY_ID=
APN_TEAM_ID=
APN_AUTH_KEY_PATH=
BUNDLE_ID=

# Test apparaat token
# Dit is het APNs token dat gelogd wordt in de Xcode console door de AppDelegate als de app start.
# Als dit token het woord 'simulator' bevat, schakelt de backend automatisch over op Mock Mode.
TEST_DEVICE_TOKEN=
