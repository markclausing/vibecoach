    "VibeCoach": {},
    "VIBECOACH": {},
    "VibeCoach gebruikt jouw eigen API-sleutel om de AI te activeren. De sleutel wordt uitsluitend lokaal op dit apparaat opgeslagen en nooit gedeeld met derden.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "VibeCoach uses your own API key to activate the AI. The key is stored only locally on this device and never shared with third parties."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "VibeCoach verwendet deinen eigenen API-Schlüssel, um die KI zu aktivieren. Der Schlüssel wird ausschließlich lokal auf diesem Gerät gespeichert und nie an Dritte weitergegeben."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "VibeCoach usa tu propia clave API para activar la IA. La clave se guarda solo localmente en este dispositivo y nunca se comparte con terceros."
          }
        }
      }
    },
    "VOEDING": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "NUTRITION"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "ERNÄHRUNG"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "NUTRICIÓN"
          }
        }
      }
    },
    "Voeding & Hydratatie": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Nutrition & Hydration"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ernährung & Flüssigkeit"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Nutrición e hidratación"
          }
        }
      }
    },
    "Voeg een nieuw fitnessdoel toe om je voortgang bij te houden.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add a new fitness goal to track your progress."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Füge ein neues Fitnessziel hinzu, um deinen Fortschritt zu verfolgen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Añade un nuevo objetivo de fitness para seguir tu progreso."
          }
        }
      }
    },
    "Voer een API-sleutel in via de Instellingen om hem wakker te maken.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Enter an API key via Settings to wake it up."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Gib einen API-Schlüssel in den Einstellungen ein, um ihn aufzuwecken."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Introduce una clave API en Ajustes para activarlo."
          }
        }
      }
    },
    "Voer je %@-sleutel in (en test 'm) om je beschikbare modellen live te laden. Tot dan tonen we een ingebouwde lijst.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Enter your %@ key (and test it) to load your available models live. Until then we show a built-in list."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Gib deinen %@-Schlüssel ein (und teste ihn), um deine verfügbaren Modelle live zu laden. Bis dahin zeigen wir eine eingebaute Liste."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Introduce tu clave de %@ (y pruébala) para cargar tus modelos disponibles en vivo. Hasta entonces mostramos una lista integrada."
          }
        }
      }
    },
