    "Leeftijd en geslacht worden gelezen uit Apple Gezondheid en zijn hier niet te bewerken. Gewicht en lengte schrijven we terug naar HealthKit.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Age and sex are read from Apple Health and can't be edited here. Weight and height we write back to HealthKit."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Alter und Geschlecht werden aus Apple Health gelesen und sind hier nicht bearbeitbar. Gewicht und Größe schreiben wir zu HealthKit zurück."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La edad y el sexo se leen de Apple Salud y no se pueden editar aquí. El peso y la altura los escribimos de vuelta en HealthKit."
          }
        }
      }
    },
    "Leeftijd en geslacht worden gelezen uit de iOS Gezondheid-app en zijn hier niet te bewerken.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Age and sex are read from the iOS Health app and can't be edited here."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Alter und Geschlecht werden aus der iOS-Health-App gelesen und sind hier nicht bearbeitbar."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La edad y el sexo se leen de la app Salud de iOS y no se pueden editar aquí."
          }
        }
      }
    },
    "Let op: Gezien je %@ was deze training extra belastend voor je herstel.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Note: given your %@, this workout was extra taxing on your recovery."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Hinweis: Angesichts deines %@ war dieses Training besonders belastend für deine Erholung."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Nota: dado tu %@, este entrenamiento fue especialmente exigente para tu recuperación."
