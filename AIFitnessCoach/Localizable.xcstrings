    "Gedetecteerd uit %lld workouts + %lld rust-dagen: %@. Handmatige waarden zijn niet overschreven.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Detected from %1$lld workouts + %2$lld rest days: %3$@. Manual values were not overwritten."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Aus %1$lld Workouts + %2$lld Ruhetagen erkannt: %3$@. Manuelle Werte wurden nicht überschrieben."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Detectado a partir de %1$lld entrenamientos + %2$lld días de descanso: %3$@. Los valores manuales no se sobrescribieron."
          }
        }
      }
    },
    "Je piekbelasting is al bereikt. Vasthouden en binnenkort beginnen met taperen.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your peak load is already reached. Hold it and start tapering soon."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Deine Spitzenbelastung ist bereits erreicht. Halten und bald mit dem Tapering beginnen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ya has alcanzado tu carga máxima. Mantenla y empieza pronto el taper."
          }
        }
      }
    },
    "Op basis van %@ groei/week ben je %lld week(en) eerder klaar dan gepland. Goed bezig!": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "At %@ growth/week you'll be ready %lld week(s) earlier than planned. Well done!"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Bei %@ Zuwachs/Woche bist du %lld Woche(n) früher bereit als geplant. Gut gemacht!"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Con un %@ de crecimiento/semana estarás listo %lld semana(s) antes de lo previsto. ¡Bien hecho!"
          }
        }
      }
    },
    "Je groeit %@ per week. Je loopt %lld week(en) achter op de geplande piekdatum. Schroef het volume op.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You're growing %@ per week. You're %lld week(s) behind the planned peak date. Ramp up the volume."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Du wächst %@ pro Woche. Du bist %lld Woche(n) hinter dem geplanten Peak-Datum. Erhöhe das Volumen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Creces un %@ por semana. Vas %lld semana(s) por detrás de la fecha de pico prevista. Aumenta el volumen."
          }
        }
      }
    },
    "fiets": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "cycling"
          }
        },
        "de": {
