    "Dagen sinds laatste training" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tage seit letztem Training"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Days since last workout"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Días desde el último entrenamiento"
          }
        }
      }
    },
    "Daling van je gemiddelde cadans tussen het eerste en laatste kwart. Zero-cadence-momenten (verkeerslicht, koffiestop) worden uit de meting gefilterd. Een fors verschil duidt op spiervermoeidheid of bewust temperen aan het einde." : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rückgang deiner durchschnittlichen Trittfrequenz zwischen dem ersten und letzten Viertel. Null-Trittfrequenz-Momente (Ampel, Kaffeepause) werden herausgefiltert. Ein großer Unterschied deutet auf muskuläre Ermüdung oder bewusstes Zurücknehmen am Ende hin."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Drop in your average cadence between the first and last quarter. Zero-cadence moments (traffic light, coffee stop) are filtered out. A large difference indicates muscular fatigue or deliberately easing off at the end."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Caída de tu cadencia media entre el primer y el último cuarto. Los momentos de cadencia cero (semáforo, parada para café) se filtran. Una diferencia grande indica fatiga muscular o aflojar deliberadamente al final."
          }
        }
      }
    },
    "Data onleesbaar (%@)." : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Daten unlesbar (%@)."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Data unreadable (%@)."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Datos ilegibles (%@)."
          }
        }
      }
    },
    "Datum ligt te dichtbij — kies minstens %lld dagen vooruit." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Datum liegt zu nah – wähle mindestens %lld Tage im Voraus."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Date is too soon — choose at least %lld days out."
          }
