    },
    "We sturen alleen een bericht als je lichaam afwijkt van je plan — gemiddeld één keer per week, nooit meer dan één per doel per dag." : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wir senden nur eine Nachricht, wenn dein Körper von deinem Plan abweicht — im Schnitt einmal pro Woche, nie mehr als eine pro Ziel und Tag."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "We only send a message when your body deviates from your plan — on average once a week, never more than one per goal per day."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Solo enviamos un mensaje cuando tu cuerpo se desvía de tu plan: de media una vez por semana, nunca más de uno por objetivo al día."
          }
        }
      }
    },
