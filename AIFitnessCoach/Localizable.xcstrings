    "Afgeleid uit je trainingsgeschiedenis. Sync 1 jaar aan historie om de coach context te geven over je fitnessniveau.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Derived from your training history. Sync 1 year of history to give the coach context about your fitness level."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Abgeleitet aus deiner Trainingshistorie. Synchronisiere 1 Jahr Historie, um dem Coach Kontext zu deinem Fitnessniveau zu geben."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Derivado de tu historial de entrenamiento. Sincroniza 1 año de historial para dar contexto al entrenador sobre tu nivel de forma."
          }
        }
      }
    },
