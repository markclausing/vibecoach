    "Max HR, rust HR, LTHR en FTP. De coach gebruikt deze waarden om jouw zones te berekenen — anders gebruikt hij populatie-gemiddelden.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Max. HF, Ruhe-HF, LTHR und FTP. Der Coach nutzt diese Werte, um deine Zonen zu berechnen — sonst verwendet er Bevölkerungsdurchschnitte."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Max HR, resting HR, LTHR and FTP. The coach uses these values to compute your zones — otherwise it uses population averages."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "FC máx., FC en reposo, LTHR y FTP. El entrenador usa estos valores para calcular tus zonas — de lo contrario usa promedios de la población."
          }
        }
      }
    },
