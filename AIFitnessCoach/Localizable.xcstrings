    "Live opgehaald met je sleutel. Lukt dat niet, dan tonen we een ingebouwde lijst.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Live mit deinem Schlüssel geladen. Falls das fehlschlägt, zeigen wir eine eingebaute Liste."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
