            "value": "ciclismo"
          }
        }
      }
    },
    "hardloop": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "running"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Lauf"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "carrera"
          }
        }
      }
    },
    "Bottleneck: %@-volume. Omdat je aerobe basis (TRIMP) sterk is, kunnen we dit gat de komende weken sneller dichten zodra je hersteld bent. Nog %lld week(en) bij te sturen — ruim op tijd.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Bottleneck: %@ volume. Because your aerobic base (TRIMP) is strong, we can close this gap faster over the coming weeks once you've recovered. %lld week(s) left to adjust — plenty of time."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Engpass: %@-Volumen. Da deine aerobe Basis (TRIMP) stark ist, können wir diese Lücke in den kommenden Wochen schneller schließen, sobald du erholt bist. Noch %lld Woche(n) zum Nachsteuern — reichlich Zeit."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuello de botella: volumen de %@. Como tu base aeróbica (TRIMP) es fuerte, podemos cerrar esta brecha más rápido en las próximas semanas una vez recuperado. Quedan %lld semana(s) para ajustar: tiempo de sobra."
          }
        }
      }
    },
    "Je loopt %lld week(en) achter, maar de racedag is nog ver genoeg weg voor een gerichte inhaalslag. Stap voor stap opbouwen.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You're %lld week(s) behind, but race day is still far enough away for a focused catch-up. Build it step by step."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Du bist %lld Woche(n) im Rückstand, aber der Renntag ist noch weit genug entfernt für eine gezielte Aufholjagd. Bau es Schritt für Schritt auf."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Vas %lld semana(s) por detrás, pero el día de carrera está aún lo bastante lejos para una recuperación enfocada. Constrúyelo paso a paso."
          }
        }
      }
    },
    "Zelfs met maximale wekelijkse groei is de piekbelasting niet haalbaar vóór de racedag. Bespreek dit met je coach.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Even with maximum weekly growth, the peak load isn't achievable before race day. Discuss this with your coach."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Selbst mit maximalem wöchentlichem Zuwachs ist die Spitzenbelastung vor dem Renntag nicht erreichbar. Besprich das mit deinem Coach."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Incluso con el máximo crecimiento semanal, la carga máxima no es alcanzable antes del día de carrera. Coméntalo con tu entrenador."
          }
        }
      }
    },
