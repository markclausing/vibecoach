    "Beide bronnen syncen altijd. Je voorkeur bepaalt welke bron de coach als eerste aanspreekt voor de huidige status.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Beide Quellen synchronisieren immer. Deine Präferenz bestimmt, welche Quelle der Coach zuerst für den aktuellen Status heranzieht."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Both sources always sync. Your preference determines which source the coach consults first for the current status."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ambas fuentes se sincronizan siempre. Tu preferencia determina qué fuente consulta primero el entrenador para el estado actual."
          }
        }
      }
    },
