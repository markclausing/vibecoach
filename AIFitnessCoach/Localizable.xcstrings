    "Controleer of de app toestemming heeft voor Workouts en Hartslag — anders blijft het Dashboard leeg.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Prüfe, ob die App die Berechtigung für Workouts und Herzfrequenz hat — sonst bleibt das Dashboard leer."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Check that the app has permission for Workouts and Heart Rate — otherwise the Dashboard stays empty."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Comprueba que la app tenga permiso para Entrenamientos y Frecuencia cardíaca — de lo contrario el panel queda vacío."
          }
        }
      }
    },
