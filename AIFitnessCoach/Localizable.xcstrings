    },
    "Live lijst niet beschikbaar — %@. Ingebouwde lijst getoond.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Live list unavailable — %@. Showing built-in list."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Live-Liste nicht verfügbar — %@. Eingebaute Liste angezeigt."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Lista en vivo no disponible — %@. Se muestra la lista integrada."
          }
        }
      }
    },
    "Live opgehaald met je sleutel. Lukt dat niet, dan tonen we een ingebouwde lijst.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Fetched live with your key. If that fails, we show a built-in list."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Live mit deinem Schlüssel geladen. Falls das fehlschlägt, zeigen wir eine eingebaute Liste."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Obtenido en vivo con tu clave. Si falla, mostramos una lista integrada."
          }
        }
      }
    },
    "Los dit op": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Fix this"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Beheben"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Resolver"
          }
        }
      }
    },
    "Max HR, rust HR, LTHR en FTP. De coach gebruikt deze waarden om jouw zones te berekenen — anders gebruikt hij populatie-gemiddelden.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Max HR, resting HR, LTHR and FTP. The coach uses these values to compute your zones — otherwise it uses population averages."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Max. HF, Ruhe-HF, LTHR und FTP. Der Coach nutzt diese Werte, um deine Zonen zu berechnen — sonst verwendet er Bevölkerungsdurchschnitte."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "FC máx., FC en reposo, LTHR y FTP. El entrenador usa estos valores para calcular tus zonas — de lo contrario usa promedios de la población."
          }
        }
      }
    },
    "Maximaal": {
