    "%@ TRIMP binnengehaald — goede stap richting '%@'. Je loopt nog iets achter, maar de coach heeft een vervolgstap klaar." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ TRIMP erreicht – ein guter Schritt Richtung '%@'. Du bist noch etwas im Rückstand, aber der Coach hat einen nächsten Schritt parat."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ TRIMP earned — a good step toward '%@'. You're still a little behind, but the coach has a next step ready."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ TRIMP conseguidos: un buen paso hacia '%@'. Aún vas un poco por detrás, pero el coach ya tiene el siguiente paso."
          }
        }
      }
    },
    "%@ TRIMP binnengehaald. Je loopt nog achter op %@ doelen, maar je bent op de goede weg. Open de coach." : {
